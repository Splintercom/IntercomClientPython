export OAUTH_CLIENT_ID=$(jq -r '.client_id' ~/.config/intercom-infra/cognito.json)
export OAUTH_CLIENT_SECRET=$(jq -r '.client_secret' ~/.config/intercom-infra/cognito.json)

export VIDEO_SOURCE=0
export TOKEN_FILE_PATH="~/.config/intercom-client/tokens.json"
export WEBSOCKET_API_BASE_URL="http://localhost:8000/ws/live_stream"
export HTTP_API_BASE_URL="http://localhost:8000"

source .venv/bin/activate
